{
  "name": "plow",
  "version": "2.96.0",
  "description": "Deterministic codebase intelligence for TypeScript and JavaScript. Quality, risk, architecture, dependencies, duplication, and safe cleanup evidence for humans, CI, and agents. Optional runtime intelligence layer (Plow Runtime) adds production execution evidence. Rust-native, sub-second, zero-config framework support.",
  "license": "LicenseRef-Tempext-Commercial",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fglogan/genesis-plow.git"
  },
  "homepage": "https://docs.genesis-plow.dev",
  "bugs": {
    "url": "https://github.com/fglogan/genesis-plow/issues"
  },
  "intent": {
    "version": 1,
    "repo": "fglogan/genesis-plow",
    "docs": "https://docs.genesis-plow.dev"
  },
  "keywords": [
    "code-intelligence",
    "code-quality",
    "pr-risk",
    "static-analysis",
    "code-duplication",
    "circular-dependencies",
    "unused-code",
    "complexity",
    "architecture",
    "typescript",
    "javascript",
    "analyzer",
    "lint",
    "lsp",
    "mcp",
    "agent-skills",
    "tanstack-intent"
  ],
  "engines": {
    "node": ">=16"
  },
  "bin": {
    "plow": "bin/plow",
    "plow-lsp": "bin/plow-lsp",
    "plow-mcp": "bin/plow-mcp"
  },
  "exports": {
    "./types": {
      "types": "./types/output-contract.d.ts"
    },
    "./package.json": "./package.json",
    "./bin/*": "./bin/*",
    "./scripts/*": "./scripts/*",
    "./skills/*": "./skills/*",
    "./schema.json": "./schema.json"
  },
  "typesVersions": {
    "*": {
      "types": [
        "./types/output-contract.d.ts"
      ]
    }
  },
  "files": [
    "bin",
    "scripts",
    "skills",
    "!skills/_artifacts",
    "types",
    "README.md",
    "schema.json"
  ],
  "scripts": {
    "test:platform": "node --test scripts/platform-package.test.js",
    "test:verify": "node --test scripts/verify-binary.test.js",
    "test:sentinel-path": "node --test scripts/sentinel-path.test.js",
    "test:lazy-verify": "node --test scripts/lazy-verify.test.js",
    "test": "node --test scripts/*.test.js"
  },
  "dependencies": {
    "detect-libc": "2.1.2"
  },
  "devDependencies": {
    "@tanstack/intent": "0.0.41"
  },
  "optionalDependencies": {
    "@plow-cli/darwin-arm64": "2.96.0",
    "@plow-cli/darwin-x64": "2.96.0",
    "@plow-cli/linux-x64-gnu": "2.96.0",
    "@plow-cli/linux-arm64-gnu": "2.96.0",
    "@plow-cli/linux-x64-musl": "2.96.0",
    "@plow-cli/linux-arm64-musl": "2.96.0",
    "@plow-cli/win32-arm64-msvc": "2.96.0",
    "@plow-cli/win32-x64-msvc": "2.96.0"
  }
}
