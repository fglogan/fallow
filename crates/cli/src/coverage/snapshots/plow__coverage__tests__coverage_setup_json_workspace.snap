---
source: crates/cli/src/coverage/mod.rs
expression: payload
---
schema_version: "1"
framework_detected: plain_node
package_manager: pnpm
runtime_targets:
  - node
  - browser
members:
  - name: "@demo/api"
    path: "."
    framework_detected: plain_node
    package_manager: pnpm
    runtime_targets:
      - node
    files_to_edit:
      - path: src/index.ts
        reason: Start the Node runtime beacon before application code handles traffic.
    snippets:
      - label: Node entrypoint
        path: src/index.ts
        content: "import { createNodeBeacon } from \"@plow-cli/beacon\";\n\nconst plowBeacon = createNodeBeacon({\n  apiKey: process.env.PLOW_API_KEY,\n  projectId: process.env.PLOW_PROJECT_ID ?? \"my-app\",\n  endpoint: process.env.PLOW_API_URL ?? \"https://api.plow.cloud\",\n  transport: process.env.PLOW_TRANSPORT === \"fs\" ? \"fs\" : \"http\",\n  writeToDir: process.env.PLOW_WRITE_TO_DIR,\n});\n\nplowBeacon.start();\n"
    dockerfile_snippet: "ENV PLOW_TRANSPORT=fs\nENV PLOW_WRITE_TO_DIR=/tmp/plow-coverage"
    warnings:
      - No local coverage artifact was detected yet.
  - name: "@demo/admin"
    path: apps/admin
    framework_detected: vite
    package_manager: pnpm
    runtime_targets:
      - browser
    files_to_edit:
      - path: apps/admin/src/main.ts
        reason: Start the browser runtime beacon from the client entry module.
    snippets:
      - label: Vite browser entry
        path: apps/admin/src/main.ts
        content: "import { createBrowserBeacon } from \"@plow-cli/beacon/browser\";\n\nconst plowBeacon = createBrowserBeacon({\n  apiKey: import.meta.env.VITE_PLOW_API_KEY,\n  projectId: import.meta.env.VITE_PLOW_PROJECT_ID ?? \"my-app\",\n  endpoint: import.meta.env.VITE_PLOW_API_URL ?? \"https://api.plow.cloud\",\n  sampleRate: 0.01,\n});\n\nplowBeacon.start();\n"
    dockerfile_snippet: ~
    warnings:
      - No local coverage artifact was detected yet.
  - name: "@demo/marketing"
    path: apps/marketing
    framework_detected: vite
    package_manager: pnpm
    runtime_targets:
      - browser
    files_to_edit:
      - path: apps/marketing/src/main.ts
        reason: Start the browser runtime beacon from the client entry module.
    snippets:
      - label: Vite browser entry
        path: apps/marketing/src/main.ts
        content: "import { createBrowserBeacon } from \"@plow-cli/beacon/browser\";\n\nconst plowBeacon = createBrowserBeacon({\n  apiKey: import.meta.env.VITE_PLOW_API_KEY,\n  projectId: import.meta.env.VITE_PLOW_PROJECT_ID ?? \"my-app\",\n  endpoint: import.meta.env.VITE_PLOW_API_URL ?? \"https://api.plow.cloud\",\n  sampleRate: 0.01,\n});\n\nplowBeacon.start();\n"
    dockerfile_snippet: ~
    warnings:
      - No local coverage artifact was detected yet.
config_written: ~
commands:
  - pnpm add @plow-cli/beacon
  - pnpm add -D @plow-cli/plow-cov
files_to_edit:
  - path: src/index.ts
    reason: Start the Node runtime beacon before application code handles traffic.
snippets:
  - label: Node entrypoint
    path: src/index.ts
    content: "import { createNodeBeacon } from \"@plow-cli/beacon\";\n\nconst plowBeacon = createNodeBeacon({\n  apiKey: process.env.PLOW_API_KEY,\n  projectId: process.env.PLOW_PROJECT_ID ?? \"my-app\",\n  endpoint: process.env.PLOW_API_URL ?? \"https://api.plow.cloud\",\n  transport: process.env.PLOW_TRANSPORT === \"fs\" ? \"fs\" : \"http\",\n  writeToDir: process.env.PLOW_WRITE_TO_DIR,\n});\n\nplowBeacon.start();\n"
dockerfile_snippet: "ENV PLOW_TRANSPORT=fs\nENV PLOW_WRITE_TO_DIR=/tmp/plow-coverage"
next_steps:
  - Add the snippets to your application.
  - Deploy with the beacon enabled.
  - Run plow health --runtime-coverage ./coverage --format json after collecting a local capture.
  - Set PLOW_API_KEY in CI before running plow coverage upload-inventory.
warnings:
  - No local coverage artifact was detected yet.
